<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLE permissions. SCAN/ADVERTISE/CONNECT are the Android 12+ model. -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Pre-Android-12 fallbacks. -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <!-- Fine location: needed only for BLE scan on API ≤30 (neverForLocation on 31+ via BLUETOOTH_SCAN).
         F-37: capped at 30 now that Wi-Fi Direct is gone - it was the only thing needing 31-32. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" android:maxSdkVersion="30" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <!-- LAN bearer (mDNS/NSD + TCP): discover and link nearby devices over a shared Wi-Fi network.
         F-37: Wi-Fi Direct was removed (commit c059d69), so its CHANGE_WIFI_STATE / NEARBY_WIFI_DEVICES
         permissions and the wifi.direct feature are dropped - NSD needs only these. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- Keep BLE alive in the background via a foreground service (DESIGN.md §22). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- Local notifications ("push") for delivered messages, Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Cloud relay bearer (TCP/WebSocket to hop-relayd over the internet). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application>
        <service
            android:name=".HopService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />
    </application>
</manifest>
